PORT=4000
APP_NAME=SecureAPI
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
USE_HTTPS=false
SSL_KEY_PATH=./certs/localhost-key.pem
SSL_CERT_PATH=./certs/localhost-cert.pem
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/secureapi?appName=secureapi
JWT_SECRET=replace_this_with_a_long_random_secret_value
JWT_EXPIRES_IN=1h
